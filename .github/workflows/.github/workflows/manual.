name: 🎬 dailyDNH – Manual Generate

on:
  workflow_dispatch:
    inputs:
      branch:
        description: "Cabang DNH"
        required: true
        default: "gateway"
        type: choice
        options: [gateway, jarrdin, grand_asia]
      room_type:
        description: "Tipe Kamar"
        required: true
        default: "studio"
        type: choice
        options: [studio, 1br, 2br]
      theme:
        description: "Tema Konten"
        required: true
        default: "promo"
        type: choice
        options: [promo, weekend, workspace, family, room_tour, testimonial, wellness]
      style:
        description: "Style Poster"
        required: true
        default: "luxury"
        type: choice
        options: [luxury, cozy, modern, minimalist]

jobs:
  manual:
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.10"
          cache: "pip"

      - run: pip install -r requirements.txt

      - name: 🎬 Manual Generate
        env:
          TELEGRAM_BOT_TOKEN: ${{ secrets.TELEGRAM_BOT_TOKEN }}
          TELEGRAM_CHAT_ID:   ${{ secrets.TELEGRAM_CHAT_ID }}
          GROQ_API_KEY:       ${{ secrets.GROQ_API_KEY }}
          MANUAL_BRANCH:      ${{ github.event.inputs.branch }}
          MANUAL_ROOM:        ${{ github.event.inputs.room_type }}
          MANUAL_THEME:       ${{ github.event.inputs.theme }}
          MANUAL_STYLE:       ${{ github.event.inputs.style }}
        run: python src/manual_generate.py

      - uses: actions/upload-artifact@v4
        if: always()
        with:
          name: manual-content-${{ github.run_id }}
          path: outputs/

      - name: 🚨 Notif jika gagal
        if: failure()
        run: |
          curl -s -X POST \
            "https://api.telegram.org/bot${{ secrets.TELEGRAM_BOT_TOKEN }}/sendMessage" \
            -d chat_id="${{ secrets.TELEGRAM_CHAT_ID }}" \
            -d text="❌ dailyDNH Manual GAGAL! Cek: ${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}"
